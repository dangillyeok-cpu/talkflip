{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://talkflip.local/schemas/cards.schema.json",
  "title": "TalkFlip Cards",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "cards"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/card"
      }
    }
  },
  "$defs": {
    "deck": {
      "type": "string",
      "enum": [
        "warm_up",
        "funny",
        "deep",
        "couple",
        "party"
      ]
    },
    "cardType": {
      "type": "string",
      "enum": [
        "answer",
        "choice",
        "vote",
        "story",
        "deep_light",
        "taboo"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "classic_flip",
        "this_or_that",
        "whos_most_likely",
        "hot_seat",
        "taboo_round"
      ]
    },
    "localizedText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 220
    },
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "deck",
        "cardType",
        "modes",
        "en",
        "ko"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(warm_up|funny|deep|couple|party)_(answer|choice|vote|story|deep_light|taboo)_[0-9]{3}$"
        },
        "deck": {
          "$ref": "#/$defs/deck"
        },
        "cardType": {
          "$ref": "#/$defs/cardType"
        },
        "modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/mode"
          }
        },
        "minPlayers": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "maxPlayers": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "tone": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "en": {
          "$ref": "#/$defs/localizedText"
        },
        "ko": {
          "$ref": "#/$defs/localizedText"
        },
        "follow": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "en",
            "ko"
          ],
          "properties": {
            "en": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "ko": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            }
          }
        },
        "bannedKo": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20
          }
        },
        "bannedEn": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 24
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "cardType": {
                "const": "taboo"
              }
            }
          },
          "then": {
            "required": [
              "bannedKo",
              "bannedEn"
            ]
          },
          "else": {
            "properties": {
              "bannedKo": false,
              "bannedEn": false
            }
          }
        }
      ]
    }
  }
}
